name = "ogb-telemetry-email-worker"
main = "worker.js"
compatibility_date = "2026-05-06"
workers_dev = true

[vars]
DIGEST_WINDOW_MINUTES = "15"
DIGEST_MAX_RECORDS = "100"

[triggers]
crons = ["*/15 * * * *"]

# Optional but recommended for digest emails. Without this binding, the Worker
# falls back to one email per envelope.
[[kv_namespaces]]
binding = "TELEMETRY_BUFFER"
id = "REPLACE_WITH_KV_NAMESPACE_ID"
preview_id = "REPLACE_WITH_PREVIEW_KV_NAMESPACE_ID"

# Configure secrets manually:
# wrangler secret put OGB_TELEMETRY_TOKEN
# wrangler secret put RESEND_API_KEY
# wrangler secret put RESEND_FROM
# wrangler secret put RESEND_TO
