{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gemini Extension Compatibility Manifest",
  "type": "object",
  "required": [
    "name",
    "version"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "gemini": {
      "type": "object"
    },
    "opencodeProjection": {
      "type": "object",
      "properties": {
        "instructions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mcp": {
          "type": "object"
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "trust": {
      "type": "object",
      "properties": {
        "requiresTrustForHooks": {
          "type": "boolean"
        },
        "requiresTrustForScripts": {
          "type": "boolean"
        }
      }
    }
  }
}
