{
  "name": "opencode-gemini-bridge",
  "version": "0.1.11",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/augustocaruso/opencode-gemini-bridge.git"
  },
  "homepage": "https://github.com/augustocaruso/opencode-gemini-bridge#readme",
  "bugs": {
    "url": "https://github.com/augustocaruso/opencode-gemini-bridge/issues"
  },
  "files": [
    "dist/**/*.js",
    "telemetry-email-worker/**/*.js",
    "telemetry-email-worker/**/*.example",
    "schemas/**/*.json",
    "telemetry.defaults.json",
    "telemetry.defaults.example.json",
    "package.json",
    "LICENSE"
  ],
  "bin": {
    "ogb": "dist/cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc && node -e \"require('node:fs').chmodSync('dist/cli.js',0o755)\"",
    "dev": "tsx src/cli.ts",
    "author:snapshot": "uv run --project authoring/ux-profile-author ogb-ux-profile-author",
    "author:test": "uv run --project authoring/ux-profile-author pytest authoring/ux-profile-author/tests",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "lint": "echo add eslint later",
    "pack:local": "npm run build && npm pack",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^6.3.1",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.6",
    "rulesync": "^8.15.0",
    "yaml": "^2.5.1"
  },
  "overrides": {
    "smol-toml": "1.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
